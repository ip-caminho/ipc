# Variáveis de ambiente do frontend (copiar para .env.local e preencher).
# Segredos de backend (B2, Deepgram, chaves de LLM, VAPID privado) NÃO ficam
# aqui — moram nas env vars do Convex (dashboard ou `npx convex env`).

# Deployment Convex (gerado por `npx convex dev` / `npx convex deploy`)
CONVEX_DEPLOYMENT=

# URLs públicas do deployment Convex
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Bypass de auth em dev (NUNCA "true" em produção)
NEXT_PUBLIC_AUTH_BYPASS_MODE=

# Web Push (chave pública VAPID; a privada fica nas env vars do Convex)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Porta local (opcional)
PORT=3000
